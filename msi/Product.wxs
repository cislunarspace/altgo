<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" UpgradeCode="B1A2C3D4-E5F6-7890-ABCD-EF1234567890"
             Name="altgo"
             Language="2052"
             Version="$(var.Version)"
             Manufacturer="altgo">

        <Package InstallerVersion="200" Compressed="yes" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="altgo" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
        </Feature>

        <Icon Id="altgo.exe" SourceFile="$(var.SourceDir)\altgo.exe" />
        <Property Id="ARPPRODUCTICON" Value="altgo.exe" />

        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="ProgramFilesFolder">
                <Directory Id="INSTALLFOLDER" Name="altgo">
                    <Component Id="MainExecutable" Guid="12345678-1234-1234-1234-123456789012">
                        <File Id="altgo.exe" Source="$(var.SourceDir)\altgo.exe" KeyPath="yes" />
                    </Component>
                </Directory>
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="altgo">
                    <Component Id="ApplicationShortcut" Guid="87654321-4321-4321-4321-210987654321">
                        <Shortcut Id="ApplicationStartMenuShortcut"
                                  Name="altgo"
                                  Description="语音转文字工具"
                                  Target="[INSTALLFOLDER]altgo.exe"
                                  WorkingDirectory="INSTALLFOLDER" />
                        <RemoveFolder Id="CleanUpShortCut" Directory="ApplicationProgramsFolder" On="uninstall" />
                        <RegistryValue Root="HKCU" Key="Software\altgo" Name="installed" Type="integer" Value="1" KeyPath="yes" />
                    </Component>
                </Directory>
            </Directory>
        </Directory>

        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
        </ComponentGroup>
    </Product>
</Wix>
